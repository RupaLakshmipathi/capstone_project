<%- include('partials/header', { title }) %>

<section class="panel narrow-panel">
  <p class="eyebrow">Seller Tools</p>
  <h1>Add a new product</h1>
  <p>Fill in all fields to publish your product in the SakhiSell marketplace.</p>

  <form action="/product/add" method="POST" class="stack-form">
    <label for="title">Product Name</label>
    <input id="title" name="title" type="text" required />

    <label for="description">Description</label>
    <textarea id="description" name="description" rows="5" required></textarea>

    <label for="price">Price</label>
    <input id="price" name="price" type="number" min="0" step="0.01" required />

    <label for="category">Category</label>
    <input id="category" name="category" type="text" required />

    <label for="image">Image URL</label>
    <input id="image" name="image" type="url" required />

    <button type="submit" class="btn btn-primary btn-full">Add Product</button>
  </form>
</section>

<%- include('partials/footer') %>
